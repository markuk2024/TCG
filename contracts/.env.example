# Local Development / Testnet Deployment Configuration
# Copy this file to .env and fill in your actual values

# Required: Your wallet's private key (WITHOUT the 0x prefix)
# WARNING: Never commit .env with real keys to git!
# For local testing: Use a key from `npx hardhat node` output
# For testnet: Create a new test wallet specifically for testing
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# Optional: BSCScan API Key for contract verification
# Get yours at: https://bscscan.com/myapikey
BSCSCAN_API_KEY=your_bscscan_api_key_here

# Optional: Custom RPC endpoints (defaults are provided in hardhat.config.js)
# BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545/
# BSC_MAINNET_RPC=https://bsc-dataseed.binance.org/

# Deployment Configuration
# NETWORK=localhost  # Options: localhost, bsctestnet, bscmainnet

# Contract Admin Addresses (update these for testnet/mainnet)
# TREASURY_WALLET=0x...
# OPERATIONS_WALLET=0x...
# TOKEN_LIQUIDITY_WALLET=0x...
# INVESTMENT_WALLET=0x...
# INVENTORY_FUND_WALLET=0x...
