# TCG Vault Protocol Backend Configuration

# Server Configuration
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5500
LOG_LEVEL=info

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tcg_vault_protocol
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key

# Stripe Configuration (Payment Processing)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Blockchain Configuration (Ethereum/Polygon)
BLOCKCHAIN_NETWORK=polygon
RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_api_key
TREASURY_WALLET_PRIVATE_KEY=your_encrypted_wallet_key
TOKEN_CONTRACT_ADDRESS=0x...
TREASURY_WALLET_ADDRESS=0x...

# Smart Contract Configuration
CONTRACT_DEPLOYER_KEY=your_deployer_private_key

# Email Service (SendGrid/Resend)
EMAIL_SERVICE=sendgrid
EMAIL_API_KEY=your_email_api_key
EMAIL_FROM=noreply@tcgvaultprotocol.com

# KYC Provider (Sumsub/Onfido)
KYC_PROVIDER=sumsub
KYC_API_KEY=your_kyc_api_key
KYC_SECRET_KEY=your_kyc_secret

# External APIs
ALCHEMY_API_KEY=your_alchemy_key
ETHERSCAN_API_KEY=your_etherscan_key

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Treasury Allocation Percentages
TREASURY_ALLOCATION_PERCENT=50
TOKEN_BUYBACK_PERCENT=30
OPERATIONS_PERCENT=20

# Staking Configuration
STAKING_REWARD_POOL_WALLET=0x...
STAKING_DISTRIBUTION_CRON=0 0 1 * *
MINIMUM_STAKE_AMOUNT=100
STAKING_APY=24

# Feature Flags
ENABLE_KYC=true
ENABLE_STAKING=true
ENABLE_FRACTIONAL_TRADING=true
ENABLE_BREAKS=true

# Admin Configuration
ADMIN_EMAIL=admin@tcgvaultprotocol.com
ADMIN_WALLET=0x...
